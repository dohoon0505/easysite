rules_version = '2';

// ─────────────────────────────────────────────────────────────
// M0 skeleton — deny-all default.
// Real per-site rules land in M1 (see plan §4).
// ─────────────────────────────────────────────────────────────
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
